      "name": "1. Franquicia",
      "item": [
        {
          "name": "01 - Crear franquicia",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201 Created', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Response tiene id y name', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.id).to.be.a('string').and.not.empty;",
                  "    pm.expect(json.name).to.eql('Nequi Colombia');",
                  "    pm.collectionVariables.set('franchiseId', json.id);",
                  "    console.log('franchiseId guardado:', json.id);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Nequi Colombia\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
