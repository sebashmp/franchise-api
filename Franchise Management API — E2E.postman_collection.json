    {
      "name": "4. Reporte Top Stock",
      "item": [
        {
          "name": "12 - Top-stock por sucursal de la franquicia",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response es un array con 2 elementos', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.be.an('array').with.lengthOf(2);",
                  "});",
                  "pm.test('Cada elemento tiene branchId, branchName y product', function () {",
                  "    var json = pm.response.json();",
                  "    json.forEach(function(item) {",
                  "        pm.expect(item).to.have.property('branchId');",
                  "        pm.expect(item).to.have.property('branchName');",
                  "        pm.expect(item).to.have.property('product');",
                  "        pm.expect(item.product).to.have.property('id');",
                  "        pm.expect(item.product).to.have.property('name');",
                  "        pm.expect(item.product).to.have.property('stock');",
                  "    });",
                  "});",
                  "pm.test('Producto top de sucursal 1 tiene stock 300 (El de Credito)', function () {",
                  "    var json = pm.response.json();",
                  "    var branch1Result = json.find(function(item) {",
                  "        return item.branchId === pm.collectionVariables.get('branchId1');",
                  "    });",
                  "    pm.expect(branch1Result).to.not.be.undefined;",
                  "    pm.expect(branch1Result.product.stock).to.eql(300);",
                  "    pm.expect(branch1Result.product.id).to.eql(pm.collectionVariables.get('productId1'));",
                  "});",
                  "pm.test('Producto top de sucursal 2 tiene stock 200 (el de Cuenta Debito)', function () {",
                  "    var json = pm.response.json();",
                  "    var branch2Result = json.find(function(item) {",
                  "        return item.branchId === pm.collectionVariables.get('branchId2');",
                  "    });",
                  "    pm.expect(branch2Result).to.not.be.undefined;",
                  "    pm.expect(branch2Result.product.stock).to.eql(200);",
                  "    pm.expect(branch2Result.product.id).to.eql(pm.collectionVariables.get('productId3'));",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
